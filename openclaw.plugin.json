{
  "id": "xe-openclaw-skill",
  "name": "Xiaoe OpenClaw Skill",
  "description": "XiaoeTech browser automation helpers for guided login and smoke checks.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": { "type": "string" },
      "loginUrl": { "type": "string" },
      "createLiveUrl": { "type": "string" },
      "storageStatePath": { "type": "string" },
      "userDataDir": { "type": "string" },
      "headless": { "type": "boolean" },
      "debugLogs": { "type": "boolean" },
      "forceXetToolRouting": { "type": "boolean" },
      "loginTimeoutMs": { "type": "number", "minimum": 1000 },
      "credentials": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string" }
        }
      }
    }
  }
}
